{
  "manifest_version": 3,
  "name": "Gridlock — Halo Column Control",
  "version": "1.1.0",
  "description": "Lock HaloPSA service desk column widths per list. Pin columns to exact pixels; fixes the auto-width rendering bug.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.halopsa.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Gridlock — pin Halo columns",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.halopsa.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
